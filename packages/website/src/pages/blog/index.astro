---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/sections/Footer.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const images = import.meta.glob<{ default: ImageMetadata }>('../../assets/blog/*.{png,jpg,jpeg,webp}', { eager: true });

const blogPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = blogPosts.sort((a, b) =>
  new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const featuredPost = sortedPosts[0];
const remainingPosts = sortedPosts.slice(1);

function getImage(post: typeof featuredPost) {
  const imageName = post.data.image?.split('/').pop();
  if (!imageName) return null;
  const imageKey = Object.keys(images).find(key => key.endsWith(imageName));
  return imageKey ? images[imageKey].default : null;
}
---

<BaseLayout
  title="Blog - ChristianAI"
  description="Explore the intersection of artificial intelligence and Christian faith through our insightful articles and spiritual guidance."
>
  <main class="blog-index">
    <!-- Hero Section -->
    <section class="blog-hero texture-overlay">
      <div class="blog-hero-inner">
        <span class="blog-hero-label">The Journal</span>
        <h1 class="blog-hero-title">Faith & Wisdom</h1>
        <div class="sacred-divider">
          <span>&#10039;</span>
        </div>
        <p class="blog-hero-subtitle">
          Exploring how biblical figures spoke with God — and what their stories mean for us today.
        </p>
      </div>
    </section>

    <!-- Featured Post -->
    {featuredPost && (() => {
      const img = getImage(featuredPost);
      return (
        <section class="featured-section">
          <div class="featured-container">
            <span class="featured-label">Latest</span>
            <a href={`/blog/${featuredPost.slug}/`} class="featured-card">
              {img && (
                <div class="featured-image-wrap">
                  <Image
                    src={img}
                    alt={featuredPost.data.title}
                    class="featured-image"
                  />
                  <div class="featured-image-overlay"></div>
                </div>
              )}
              <div class="featured-content">
                <div class="featured-meta">
                  <time datetime={featuredPost.data.pubDate.toISOString()}>
                    {featuredPost.data.pubDate.toLocaleDateString('en-US', {
                      year: 'numeric', month: 'long', day: 'numeric'
                    })}
                  </time>
                  <span class="featured-meta-dot"></span>
                  <span>{featuredPost.data.author}</span>
                </div>
                <h2 class="featured-title">{featuredPost.data.title}</h2>
                <p class="featured-desc">{featuredPost.data.description}</p>
                <span class="featured-read-more">
                  Read Article
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </span>
              </div>
            </a>
          </div>
        </section>
      );
    })()}

    <!-- Posts Grid -->
    <section class="posts-section">
      <div class="posts-container">
        <div class="posts-grid stagger-children">
          {remainingPosts.map((post, i) => {
            const img = getImage(post);
            return (
              <article class={`post-card ${i === 0 || i === 3 ? 'post-card--wide' : ''}`}>
                <a href={`/blog/${post.slug}/`} class="post-card-link">
                  {img && (
                    <div class="post-card-image-wrap">
                      <Image
                        src={img}
                        alt={post.data.title}
                        class="post-card-image"
                      />
                    </div>
                  )}
                  <div class="post-card-body">
                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="post-card-tags">
                        {post.data.tags.slice(0, 2).map((tag) => (
                          <span class="post-card-tag">{tag}</span>
                        ))}
                      </div>
                    )}
                    <h3 class="post-card-title">{post.data.title}</h3>
                    <p class="post-card-desc">{post.data.description}</p>
                    <div class="post-card-meta">
                      <time datetime={post.data.pubDate.toISOString()}>
                        {post.data.pubDate.toLocaleDateString('en-US', {
                          month: 'short', day: 'numeric', year: 'numeric'
                        })}
                      </time>
                    </div>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Empty State -->
    {sortedPosts.length === 0 && (
      <div class="empty-state">
        <div class="sacred-divider"><span>&#10039;</span></div>
        <h2>Coming Soon</h2>
        <p>
          We're crafting insightful articles about faith and AI.
          Check back soon for our latest writings.
        </p>
      </div>
    )}
  </main>
  <Footer />
</BaseLayout>

<style>
  /* Blog Index Page */
  .blog-index {
    min-height: 100vh;
    background-color: var(--color-parchment);
  }

  /* Hero */
  .blog-hero {
    padding: 6rem 1.5rem 4rem;
    text-align: center;
    background-color: var(--color-ink);
    color: var(--color-parchment);
    position: relative;
    overflow: hidden;
  }

  .blog-hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 120px;
    background: linear-gradient(to top, var(--color-parchment), transparent);
    pointer-events: none;
  }

  .blog-hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .blog-hero-label {
    display: inline-block;
    font-family: 'Esteban', Georgia, serif;
    font-size: 0.8rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-ochre);
    margin-bottom: 1.5rem;
  }

  .blog-hero-title {
    font-family: 'Baskervville', Georgia, serif;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 1.5rem;
    color: var(--color-cream);
  }

  .blog-hero .sacred-divider {
    color: var(--color-ochre);
    margin-bottom: 1.5rem;
  }

  .blog-hero .sacred-divider::before,
  .blog-hero .sacred-divider::after {
    background: linear-gradient(90deg, transparent, var(--color-ochre-dark), transparent);
  }

  .blog-hero-subtitle {
    font-family: 'Esteban', Georgia, serif;
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-ochre-light);
    max-width: 540px;
    margin: 0 auto;
  }

  /* Featured Section */
  .featured-section {
    padding: 0 1.5rem;
    margin-top: -3rem;
    position: relative;
    z-index: 3;
  }

  .featured-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .featured-label {
    display: inline-block;
    font-family: 'Esteban', Georgia, serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-ochre);
    margin-bottom: 1rem;
    padding-left: 0.25rem;
  }

  .featured-card {
    display: grid;
    grid-template-columns: 1fr;
    background: var(--color-cream);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1),
                box-shadow 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    box-shadow: 0 4px 40px rgba(26, 22, 18, 0.08);
  }

  .featured-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 60px rgba(26, 22, 18, 0.15);
  }

  @media (min-width: 768px) {
    .featured-card {
      grid-template-columns: 1.2fr 1fr;
    }
  }

  .featured-image-wrap {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  .featured-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .featured-card:hover .featured-image {
    transform: scale(1.04);
  }

  .featured-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(26, 22, 18, 0.1) 0%, transparent 60%);
    pointer-events: none;
  }

  .featured-content {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Esteban', Georgia, serif;
    font-size: 0.8rem;
    color: var(--color-stone);
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }

  .featured-meta-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-ochre);
  }

  .featured-title {
    font-family: 'Baskervville', Georgia, serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin-bottom: 1rem;
    transition: color 0.3s ease;
  }

  .featured-card:hover .featured-title {
    color: var(--color-terracotta);
  }

  .featured-desc {
    font-family: 'Esteban', Georgia, serif;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-warm-gray);
    margin-bottom: 1.5rem;
  }

  .featured-read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Esteban', Georgia, serif;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ochre-dark);
    transition: gap 0.3s ease;
  }

  .featured-card:hover .featured-read-more {
    gap: 0.75rem;
    color: var(--color-terracotta);
  }

  /* Posts Grid */
  .posts-section {
    padding: 4rem 1.5rem 6rem;
  }

  .posts-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .posts-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .post-card--wide {
      grid-column: span 2;
    }
  }

  /* Post Card */
  .post-card {
    background: var(--color-cream);
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1),
                box-shadow 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    position: relative;
  }

  .post-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 1.5rem;
    right: 1.5rem;
    height: 2px;
    background: var(--gradient-sacred);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 40px rgba(26, 22, 18, 0.1);
  }

  .post-card:hover::after {
    transform: scaleX(1);
  }

  .post-card-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .post-card-image-wrap {
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  .post-card--wide .post-card-image-wrap {
    aspect-ratio: 21/9;
  }

  .post-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .post-card:hover .post-card-image {
    transform: scale(1.05);
  }

  .post-card-body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .post-card-tags {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .post-card-tag {
    font-family: 'Esteban', Georgia, serif;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ochre-dark);
    background: rgba(196, 163, 90, 0.1);
    padding: 0.25rem 0.6rem;
  }

  .post-card-title {
    font-family: 'Baskervville', Georgia, serif;
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin-bottom: 0.75rem;
    transition: color 0.3s ease;
  }

  .post-card:hover .post-card-title {
    color: var(--color-terracotta);
  }

  .post-card--wide .post-card-title {
    font-size: 1.4rem;
  }

  .post-card-desc {
    font-family: 'Esteban', Georgia, serif;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-warm-gray);
    margin-bottom: 1rem;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-meta {
    font-family: 'Esteban', Georgia, serif;
    font-size: 0.78rem;
    color: var(--color-stone);
    letter-spacing: 0.02em;
    border-top: 1px solid rgba(92, 87, 78, 0.12);
    padding-top: 0.75rem;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 6rem 1.5rem;
    max-width: 480px;
    margin: 0 auto;
  }

  .empty-state h2 {
    font-family: 'Baskervville', Georgia, serif;
    font-size: 2rem;
    color: var(--color-ink);
    margin: 1.5rem 0 1rem;
  }

  .empty-state p {
    font-family: 'Esteban', Georgia, serif;
    color: var(--color-warm-gray);
    line-height: 1.7;
  }
</style>
