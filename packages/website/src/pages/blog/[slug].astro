---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/sections/Footer.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const images = import.meta.glob<{ default: ImageMetadata }>('../../assets/blog/*.{png,jpg,jpeg,webp}', { eager: true });
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post) => {
    const imageName = post.data.image?.split('/').pop();
    let featuredImage = null;
    if (imageName) {
      const imageKey = Object.keys(images).find(key => key.endsWith(imageName));
      if (imageKey) featuredImage = images[imageKey].default;
    }
    return { params: { slug: post.slug }, props: { post, featuredImage } };
  });
}

const { post, featuredImage } = Astro.props;
const { Content } = await post.render();

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

// Prefer posts sharing tags, then fallback to recent
const currentTags = new Set(post.data.tags || []);
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug)
  .map(p => ({
    post: p,
    score: (p.data.tags || []).filter(t => currentTags.has(t)).length
  }))
  .sort((a, b) => b.score - a.score || new Date(b.post.data.pubDate).getTime() - new Date(a.post.data.pubDate).getTime())
  .slice(0, 3)
  .map(r => r.post);

// Estimate reading time (~200 wpm)
const wordCount = post.body?.split(/\s+/).length || 0;
const readTime = Math.max(1, Math.ceil(wordCount / 200));
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
  url={`/blog/${post.slug}/`}
>
  <main class="article-page">
    <!-- Article Header -->
    <header class="article-header texture-overlay">
      <div class="article-header-inner">
        <div class="article-breadcrumb">
          <BreadcrumbNav items={[
            { label: 'Blog', href: '/blog/' },
            { label: post.data.title }
          ]} />
        </div>

        {post.data.tags && post.data.tags.length > 0 && (
          <div class="article-tags">
            {post.data.tags.slice(0, 3).map((tag) => (
              <span class="article-tag">{tag}</span>
            ))}
          </div>
        )}

        <h1 class="article-title">{post.data.title}</h1>

        <p class="article-description">{post.data.description}</p>

        <div class="article-meta">
          <div class="article-meta-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric', month: 'long', day: 'numeric'
              })}
            </time>
          </div>
          <span class="article-meta-dot"></span>
          <div class="article-meta-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            <span>{post.data.author}</span>
          </div>
          <span class="article-meta-dot"></span>
          <div class="article-meta-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
            </svg>
            <span>{readTime} min read</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Featured Image -->
    {featuredImage && (
      <div class="article-hero-image">
        <div class="article-hero-image-inner">
          <Image
            src={featuredImage}
            alt={post.data.title}
            class="article-hero-img"
          />
          <div class="article-hero-image-border"></div>
        </div>
      </div>
    )}

    <!-- Article Body -->
    <div class="article-body">
      <article class="article-content prose">
        <Content />
      </article>

      <!-- Article Footer -->
      <div class="article-footer">
        <div class="article-footer-divider">
          <div class="sacred-divider"><span>&#10039;</span></div>
        </div>

        <div class="article-actions">
          <a href="/blog/" class="article-back-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M15 19l-7-7 7-7"/>
            </svg>
            Back to Journal
          </a>
        </div>
      </div>
    </div>

    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <section class="related-section">
        <div class="related-inner">
          <div class="related-header">
            <span class="related-label">Continue Reading</span>
            <h2 class="related-title">Related Articles</h2>
          </div>

          <div class="related-grid">
            {relatedPosts.map((relatedPost) => (
              <a href={`/blog/${relatedPost.slug}/`} class="related-card">
                <div class="related-card-number" aria-hidden="true"></div>
                <h3 class="related-card-title">{relatedPost.data.title}</h3>
                <p class="related-card-desc">{relatedPost.data.description}</p>
                <div class="related-card-meta">
                  <time datetime={relatedPost.data.pubDate.toISOString()}>
                    {relatedPost.data.pubDate.toLocaleDateString('en-US', {
                      month: 'short', day: 'numeric', year: 'numeric'
                    })}
                  </time>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
  <Footer />
</BaseLayout>

<style>
  .article-page {
    min-height: 100vh;
    background-color: var(--color-parchment);
  }

  /* Header */
  .article-header {
    background-color: var(--color-ink);
    color: var(--color-parchment);
    padding: 5rem 1.5rem 4rem;
    text-align: center;
    position: relative;
  }

  .article-header-inner {
    max-width: 760px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .article-breadcrumb {
    margin-bottom: 2rem;
    opacity: 0.7;
  }

  .article-breadcrumb :global(a) {
    color: var(--color-ochre-light) !important;
  }

  .article-breadcrumb :global(span),
  .article-breadcrumb :global(li) {
    color: var(--color-stone) !important;
  }

  .article-tags {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .article-tag {
    font-family: 'Esteban', Georgia, serif;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-ochre);
    border: 1px solid rgba(196, 163, 90, 0.3);
    padding: 0.3rem 0.75rem;
  }

  .article-title {
    font-family: 'Baskervville', Georgia, serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-cream);
    margin-bottom: 1.25rem;
  }

  .article-description {
    font-family: 'Esteban', Georgia, serif;
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-stone);
    max-width: 600px;
    margin: 0 auto 1.5rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    font-family: 'Esteban', Georgia, serif;
    font-size: 0.82rem;
    color: var(--color-stone);
  }

  .article-meta-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .article-meta-item svg {
    opacity: 0.5;
  }

  .article-meta-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-ochre-dark);
  }

  /* Hero Image */
  .article-hero-image {
    padding: 0 1.5rem;
    margin-top: -2rem;
    position: relative;
    z-index: 3;
  }

  .article-hero-image-inner {
    max-width: 860px;
    margin: 0 auto;
    position: relative;
  }

  .article-hero-img {
    width: 100%;
    max-height: 460px;
    object-fit: cover;
    display: block;
  }

  .article-hero-image-border {
    position: absolute;
    inset: 8px;
    border: 1px solid rgba(196, 163, 90, 0.2);
    pointer-events: none;
  }

  /* Article Body */
  .article-body {
    max-width: 720px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 4rem;
  }

  /* Drop cap on first paragraph */
  .article-content :global(p:first-of-type::first-letter) {
    font-family: 'Baskervville', Georgia, serif;
    font-size: 3.8em;
    float: left;
    line-height: 0.8;
    margin-right: 0.08em;
    margin-top: 0.05em;
    color: var(--color-terracotta);
  }

  /* Footer */
  .article-footer {
    margin-top: 3rem;
  }

  .article-footer-divider {
    margin-bottom: 2rem;
  }

  .article-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .article-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Esteban', Georgia, serif;
    font-size: 0.9rem;
    color: var(--color-warm-gray);
    text-decoration: none;
    transition: color 0.3s ease, gap 0.3s ease;
  }

  .article-back-link:hover {
    color: var(--color-terracotta);
    gap: 0.75rem;
  }

  /* Related Section */
  .related-section {
    background: var(--color-ink);
    padding: 5rem 1.5rem;
  }

  .related-inner {
    max-width: 1000px;
    margin: 0 auto;
  }

  .related-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .related-label {
    font-family: 'Esteban', Georgia, serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-ochre);
  }

  .related-title {
    font-family: 'Baskervville', Georgia, serif;
    font-size: 2rem;
    font-weight: 400;
    color: var(--color-cream);
    margin-top: 0.5rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: rgba(196, 163, 90, 0.15);
    counter-reset: related;
  }

  @media (min-width: 768px) {
    .related-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .related-card {
    background: var(--color-ink);
    padding: 2rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.3s ease;
    position: relative;
    counter-increment: related;
  }

  .related-card:hover {
    background: rgba(250, 248, 243, 0.04);
  }

  .related-card-number::before {
    content: "0" counter(related);
    font-family: 'Baskervville', Georgia, serif;
    font-size: 2.5rem;
    color: rgba(196, 163, 90, 0.15);
    line-height: 1;
    display: block;
    margin-bottom: 1rem;
  }

  .related-card-title {
    font-family: 'Baskervville', Georgia, serif;
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--color-cream);
    line-height: 1.35;
    margin-bottom: 0.75rem;
    transition: color 0.3s ease;
  }

  .related-card:hover .related-card-title {
    color: var(--color-ochre-light);
  }

  .related-card-desc {
    font-family: 'Esteban', Georgia, serif;
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-stone);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .related-card-meta {
    font-family: 'Esteban', Georgia, serif;
    font-size: 0.75rem;
    color: rgba(92, 87, 78, 0.7);
    letter-spacing: 0.02em;
  }
</style>
